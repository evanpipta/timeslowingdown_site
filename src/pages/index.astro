  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      var link = document.querySelector("[data-spotify-link]");
      if (!link) return;

      link.addEventListener("click", function (e) {
        var href = link.getAttribute("href");
        var match = href && href.match(/\/(artist|track|album)\/([a-zA-Z0-9]+)/);
        if (!match) return;

        var type = match[1];
        var id = match[2];
        var ua = navigator.userAgent;

        if (/android/i.test(ua)) {
          e.preventDefault();
          window.location.href =
            "intent://open.spotify.com/" + type + "/" + id +
            "#Intent;package=com.spotify.music;scheme=https;end";
        } else if (/iphone|ipad|ipod/i.test(ua)) {
          e.preventDefault();
          var fallbackTimeout;

          function onVisChange() {
            if (document.hidden) {
              clearTimeout(fallbackTimeout);
              document.removeEventListener("visibilitychange", onVisChange);
            }
          }

          document.addEventListener("visibilitychange", onVisChange);
          window.location.href = "spotify://" + type + "/" + id;

          fallbackTimeout = setTimeout(function () {
            document.removeEventListener("visibilitychange", onVisChange);
            window.location.href = href;
          }, 1500);
        }
      });
    });
  </script>
