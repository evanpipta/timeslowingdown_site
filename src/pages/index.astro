<style>
  .artist-name {
    font-family: "BBH Bartle", sans-serif;
    font-weight: 400;
    font-style: normal;
    font-size: 1rem;
    text-transform: lowercase;
    letter-spacing: -0.04em;
    color: #ffffff;
    filter: grayscale(1) brightness(3);
    animation: lfo 0.5s ease-in-out infinite;
  }

  .artist-name:hover {
    text-shadow:
      -3.5px 0 rgba(255, 255, 255, 0.75),
      3.5px 0 rgba(255, 255, 255, 0.75);
  }

  @keyframes lfo {
    0%,
    100% {
      text-shadow: none;
    }
    50% {
      text-shadow:
        -3px 0 rgba(255, 255, 255, 0.7),
        3px 0 rgba(255, 255, 255, 0.7);
    }
  }

  /* Page layout */
  .site {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 4rem 2rem;
    gap: 3.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .panel {
    width: 100%;
    max-width: 380px;
  }

  /* Header */
  .header {
    text-align: center;
  }

  /* Section headings */
  .section-heading {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.5;
    margin-bottom: 1rem;
    text-align: center;
    text-shadow:
      -1px 0 rgba(255, 255, 255, 0.55),
      1px 0 rgba(255, 255, 255, 0.55);
  }

  /* Links section */
  .links {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .link-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  .link-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.6rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 4px;
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    opacity: 0.8;
    transition:
      opacity 0.2s,
      border-color 0.2s,
      box-shadow 0.2s,
      text-shadow 0.2s;
    text-shadow:
      -1px 0 rgba(255, 255, 255, 0.5),
      1px 0 rgba(255, 255, 255, 0.5);
    box-shadow:
      -1px 0 0 rgba(255, 255, 255, 0.4),
      1px 0 0 rgba(255, 255, 255, 0.4);
  }

  .link-row:hover {
    opacity: 1;
    border-color: rgba(255, 255, 255, 0.5);
    text-shadow:
      -2px 0 rgba(255, 255, 255, 0.65),
      2px 0 rgba(255, 255, 255, 0.65);
    box-shadow:
      -2.5px 0 0 rgba(255, 255, 255, 0.6),
      2.5px 0 0 rgba(255, 255, 255, 0.6);
  }

  .link-icon {
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.9;
  }

  /* Contact section */
  .contact {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .contact-email {
    font-size: 0.95rem;
    opacity: 0.8;
    transition:
      opacity 0.2s,
      text-shadow 0.2s;
    text-shadow:
      -1px 0 rgba(255, 255, 255, 0.5),
      1px 0 rgba(255, 255, 255, 0.5);
  }

  .contact-email:hover {
    opacity: 1;
    text-shadow:
      -2px 0 rgba(255, 255, 255, 0.65),
      2px 0 rgba(255, 255, 255, 0.65);
  }

  .contact-location {
    font-size: 0.85rem;
    opacity: 0.5;
    text-transform: lowercase;
    text-shadow:
      -1px 0 rgba(255, 255, 255, 0.45),
      1px 0 rgba(255, 255, 255, 0.45);
  }

  /* Responsive */
  @media (max-width: 480px) {
    .site {
      padding: 3rem 1.5rem;
      gap: 2.5rem;
    }
  }
</style>
