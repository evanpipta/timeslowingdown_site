---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={albumArt} />
    <meta property="og:type" content="music.song" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&display=swap"
      rel="stylesheet"
    />

    <!-- Meta Pixel -->
    <script is:inline define:vars={{ trackName }}>
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () {
          n.callMethod
            ? n.callMethod.apply(n, arguments)
            : n.queue.push(arguments);
        };
        if (!f._fbq) f._fbq = n;
        n.push = n;
        n.loaded = !0;
        n.version = "2.0";
        n.queue = [];
        t = b.createElement(e);
        t.async = !0;
        t.src = v;
        s = b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t, s);
      })(
        window,
        document,
        "script",
        "https://connect.facebook.net/en_US/fbevents.js",
      );

      fbq("init", "969571118877327");
      fbq("set", "autoConfig", "false");
      fbq("track", "PageView");
      fbq("track", "ViewContent", {
        content_name: trackName,
        content_category: "music",
      });
    </script>
    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=969571118877327&ev=PageView&noscript=1"
      />
    </noscript>

    <slot name="head" />
  </head>
  <body>
    <div class="bg-cover" style={`background-image: url(${albumArt})`}></div>
    <main class="landing">
      <div class="landing-content">
        <img
          src={albumArt}
          alt={`${trackName} album art`}
          class="album-art"
          width="400"
          height="400"
        />

        <div class="track-info">
          <p class="artist-name">{artistName}</p>
          <h1 class="track-name">{trackName}</h1>
        </div>

        {
          spotifyUrl ? (
            <a
              href={spotifyUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="cta-button"
              data-track="cta-spotify"
            >
              <img
                src="https://storage.googleapis.com/pr-newsroom-wp/1/2023/05/Spotify_Primary_Logo_RGB_Black.png"
                alt="Spotify"
                class="spotify-logo"
              />
              <span>Play on Spotify</span>
            </a>
          ) : (
            <p class="coming-soon">Coming Soon</p>
          )
        }
      </div>

      <!-- social icons hidden for now -->
    </main>

    <script is:inline>
      document.addEventListener("DOMContentLoaded", function () {
        var cta = document.querySelector('[data-track="cta-spotify"]');
        if (cta) {
          cta.addEventListener("click", function () {
            fbq("trackCustom", "SocialClick", {
              platform: "Spotify",
              content_name: cta.closest(".landing").querySelector(".track-name")
                .textContent,
            });
          });
        }
      });
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    overflow-x: hidden;
    background-color: #000000;
    color: #ffffff;
    font-family: "Oswald", "Helvetica Neue", Arial, sans-serif;
    line-height: 1.5;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: #ffffff;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }
</style>

<style>
  .bg-cover {
    position: fixed;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: blur(20px);
    transform: scale(1.1);
  }

  .bg-cover::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.8);
  }

  .landing {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 3rem 1rem;
  }

  .landing-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    justify-content: center;
    gap: 1.75rem;
    width: 100%;
    max-width: 500px;
  }

  .album-art {
    width: 100%;
    max-width: 500px;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    border-radius: 0px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.6);
  }

  .track-info {
    text-align: center;
  }

  .artist-name {
    font-size: 1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    opacity: 0.7;
    margin-bottom: 0.25rem;
  }

  .track-name {
    font-size: 2rem;
    font-weight: 500;
    /* letter-spacing: 0.02em; */
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1rem 2.25rem;
    background: #1db954;
    color: #000;
    border-radius: 500px;
    font-family: inherit;
    font-size: 1.75rem;
    font-weight: 500;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .cta-button:hover {
    background: #1ed760;
  }

  .cta-button:active {
    background: #19a34a;
  }

  .spotify-logo {
    width: 40px;
    height: 40px;
    object-fit: contain;
    margin-right: 0.5rem;
    flex-shrink: 0;
  }

  .coming-soon {
    font-size: 1rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.5;
  }

  .social-icons {
    display: flex;
    gap: 1.25rem;
    padding-top: 3rem;
    padding-bottom: 1rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    opacity: 0.5;
    transition:
      opacity 0.2s,
      border-color 0.2s;
  }

  .social-icon:hover {
    opacity: 1;
    border-color: rgba(255, 255, 255, 0.5);
  }

  @media (max-width: 480px) {
    .landing {
      padding: 2rem 16px;
    }

    .album-art {
      max-width: calc(100vw - 32px);
    }

    .track-name {
      font-size: 1.35rem;
    }
  }
</style>
